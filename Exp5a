<!DOCTYPE html>
<html>
<head>
<style>
  /* --- Added Background for the whole page --- */
  body {
    background-color: black; 
    font-family: sans-serif;
    padding: 20px;
  }

  .box { width: 200px; padding: 10px; margin: 5px; color: white; }
  
  /* 1. Color Keyword */
  .keyword { background-color: tomato; }
  
  /* 2. Hexadecimal (Hex) */
  .hex { background-color: #3498db; }
  
  /* 3. RGB (Red, Green, Blue) */
  .rgb { background-color: rgb(46, 204, 113); }
  
  /* 4. RGBA (with Alpha/Transparency) */
  .rgba { background-color: rgba(155, 89, 182, 0.5); }
  
  /* 5. HSL (Hue, Saturation, Lightness) */
  .hsl { background-color: hsl(20, 100%, 50%); }
</style>
</head>
<body>
  <div class="box keyword">Keyword (tomato)</div>
  <div class="box hex">Hex (#3498db)</div>
  <div class="box rgb">RGB (46, 204, 113)</div>
  <div class="box rgba">RGBA (Transparency)</div>
  <div class="box hsl">HSL (20, 100%, 50%)</div>
</body>
</html>
